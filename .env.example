# Copy to .env and fill in. .env is gitignored.

# Required: a GW2 API key (account.arena.net/applications) with scopes:
# account, tradingpost, characters, wvw, pvp, progression, wallet, guilds,
# builds, inventories, unlocks
GW2_API_KEY=

# --- OTLP export (defaults shown) ---
# Local LGTM dev: http://localhost:4318 (or http://otel-lgtm:4318 in compose).
# Grafana Cloud (direct or via Alloy): set the OTLP endpoint + auth headers.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instanceID:token)>

# --- Optional tuning ---
# GW2_LOG_LEVEL=info            # debug|info|warn|error
# GW2_EXPORT_INTERVAL=30s
# GW2_INTERVAL_ACCOUNT=5m
# GW2_INTERVAL_WALLET=5m
# GW2_INTERVAL_CHARACTERS=5m
# GW2_INTERVAL_COMMERCE=5m
# GW2_INTERVAL_REFERENCE=1h     # how often to check /v2/build for id->name refresh
# GW2_SCHEMA_VERSION=latest
# GW2_RATE_LIMIT_PER_SEC=5
# GW2_RATE_BURST=300
