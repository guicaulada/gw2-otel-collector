      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_max(max(gw2_account_luck_total) * 300 / 4295450, 300)",
