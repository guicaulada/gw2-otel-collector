        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Magic Find %",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
