      "title": "Luck consumed",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(gw2_account_luck_total)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "luck"
        }
      ],
      "id": 12,
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Wizard's Vault objectives completed",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (gw2_period) (gw2_wizardsvault_objectives_completed)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{gw2_period}}"
        }
      ],
      "id": 13,
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "bargauge",
      "title": "Story completion % by season",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * max by (gw2_season) (gw2_story_quests_completed) / max by (gw2_season) (gw2_story_quests_total)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{gw2_season}}",
          "instant": true
        }
      ],
      "id": 14,
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 9
      }
    },
    {
      "type": "table",
      "title": "Mastery points by region",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "earned",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (gw2_region) (gw2_account_mastery_points_earned_total)"
        },
        {
          "refId": "spent",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (gw2_region) (gw2_account_mastery_points_spent)"
        }
      ],
      "id": 15,
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 9
      }
    },
    {
      "type": "timeseries",
      "title": "Reset-cycle completions (since reset)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (gw2_kind) (gw2_account_reset_completed)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{gw2_kind}}"
        }
      ],
      "id": 16,
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 7
      }
    }
