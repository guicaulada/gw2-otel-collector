{
  "uid": "gw2-pvp-ops",
  "title": "GW2 PvP & Collector Health",
  "tags": [
    "gw2"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "PvP rank",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(gw2_pvp_rank)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Rank points",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(gw2_pvp_rank_points)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 2,
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Wins",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(gw2_pvp_matches_total{gw2_outcome=\"win\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 3,
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Losses",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(gw2_pvp_matches_total{gw2_outcome=\"loss\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 4,
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Win rate %",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * max(gw2_pvp_matches_total{gw2_outcome=\"win\"}) / clamp_min(max(gw2_pvp_matches_total{gw2_outcome=\"win\"}) + max(gw2_pvp_matches_total{gw2_outcome=\"loss\"}), 1)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 5,
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      }
    },
    {
      "type": "timeseries",
      "title": "PvP matches by outcome",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (gw2_outcome) (gw2_pvp_matches_total)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{gw2_outcome}}"
        }
      ],
      "id": 6,
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 7
      }
    },
    {
      "type": "timeseries",
      "title": "PvP wins by profession & ladder",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (gw2_profession) (gw2_pvp_profession_matches_total{gw2_outcome=\"win\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "prof {{gw2_profession}}"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "ladder {{gw2_ladder}}",
          "expr": "max by (gw2_ladder) (gw2_pvp_ladder_matches_total{gw2_outcome=\"win\"})"
        }
      ],
      "id": 7,
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 7
      }
    },
    {
      "type": "timeseries",
      "title": "API request rate (req/s) by endpoint",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (gw2_endpoint) (rate(gw2_api_requests_total[5m]))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{gw2_endpoint}}"
        }
      ],
      "id": 8,
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "API request p95 latency (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gw2_api_request_duration_seconds_bucket[5m])))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "p95"
        }
      ],
      "id": 9,
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "table",
      "title": "Seconds since last successful poll",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "time() - max by (gw2_family) (gw2_poll_last_success_timestamp_seconds)"
        }
      ],
      "id": 10,
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 8,
        "h": 9
      }
    },
    {
      "type": "logs",
      "title": "Recent events",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"gw2-otel-collector\"}",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ],
      "id": 11,
      "gridPos": {
        "x": 8,
        "y": 19,
        "w": 16,
        "h": 9
      }
    }
  ]
}
