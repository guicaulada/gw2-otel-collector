{
  "uid": "gw2-characters",
  "title": "GW2 Characters",
  "tags": [
    "gw2"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "Characters",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(gw2_account_characters)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Total playtime (h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(max by (gw2_character_name) (gw2_character_playtime_seconds_total)) / 3600",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 2,
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Total deaths",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(max by (gw2_character_name) (gw2_character_deaths_total))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 3,
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      }
    },
    {
      "type": "bargauge",
      "title": "Level by character",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "min": 0,
          "max": 80
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (gw2_character_name) (gw2_character_level)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{gw2_character_name}}",
          "instant": true
        }
      ],
      "id": 4,
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 8,
        "h": 10
      }
    },
    {
      "type": "bargauge",
      "title": "Playtime by character (h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "continuous-GrYlRd"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (gw2_character_name) (gw2_character_playtime_seconds_total) / 3600",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{gw2_character_name}}",
          "instant": true
        }
      ],
      "id": 5,
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 8,
        "h": 10
      }
    },
    {
      "type": "bargauge",
      "title": "Deaths by character",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "continuous-GrYlRd"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (gw2_character_name) (gw2_character_deaths_total)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{gw2_character_name}}",
          "instant": true
        }
      ],
      "id": 6,
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 10
      }
    }
  ]
}
