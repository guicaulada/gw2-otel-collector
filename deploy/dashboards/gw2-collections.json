{
  "uid": "gw2-collections",
  "title": "GW2 Collections",
  "tags": [
    "gw2"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "bargauge",
      "title": "Collection completion %",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calc": "lastNotNull"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * max by (gw2_collection) (gw2_account_unlocks_count) / max by (gw2_collection) (gw2_account_unlocks_total)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{gw2_collection}}",
          "instant": true
        }
      ],
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 12
      }
    },
    {
      "type": "table",
      "title": "Owned / total per collection",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "owned",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (gw2_collection) (gw2_account_unlocks_count)"
        },
        {
          "refId": "total",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (gw2_collection) (gw2_account_unlocks_total)"
        }
      ],
      "id": 2,
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 12
      }
    }
  ]
}
